{
  "version": 3,
  "installCommand": "npm install --legacy-peer-deps",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    },
    { "src": "server/api.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/server/api.ts" },
    { "src": "/manus-storage/(.*)", "dest": "/server/api.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
